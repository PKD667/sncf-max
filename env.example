# SNCF Max Configuration
# Copy this file to .env and fill in your values

# === Authentication (required for booking) ===
SNCF_EMAIL=your.email@example.com
SNCF_PASSWORD=your_password

# === Proxy Configuration (optional) ===
# HTTP/HTTPS proxy for API requests
# SNCF_PROXY=http://proxy.example.com:8080
# SNCF_PROXY=http://user:password@proxy.example.com:8080
# SNCF_PROXY=socks5://proxy.example.com:1080

# Separate proxy for browser automation (if different)
# SNCF_PROXY_BROWSER=http://proxy.example.com:8080

# === Browser Settings (optional) ===
# Run browser in headless mode (default: true)
SNCF_HEADLESS=true

# === Debug Settings (optional) ===
# Enable debug mode for verbose output
SNCF_DEBUG=false

# === Notification Settings (optional) ===
# SMTP settings for email notifications
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your.email@gmail.com
# SMTP_PASSWORD=your_app_password
# NOTIFY_EMAIL=your.email@example.com

# Webhook URL for notifications
# WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz


